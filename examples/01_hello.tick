# 01_hello.tick - Basic function definition and calling

# Simple function that returns a value
let add = fn(x: i32, y: i32) -> i32 {
    return x + y;
};

# Function with no return value
let print_sum = fn(a: i32, b: i32) {
    let result = add(a, b);
    # Note: In real implementation, would use I/O operations
    return;
};

# Entry point
pub let main = fn() -> i32 {
    let x = 10;
    let y = 20;
    let sum = add(x, y);

    print_sum(x, y);

    return 0;
};
